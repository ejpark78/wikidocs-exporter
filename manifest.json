{
  "manifest_version": 3,
  "name": "WikiDocs Exporter",
  "version": "1.2.1",
  "description": "위키독스 컨텐츠를 Obsidian 또는 Joplin으로 내보내기",
  "homepage_url": "https://github.com/ejpark78/wikidocs-exporter",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "clipboardWrite",
    "sidePanel",
    "scripting"
  ],
  "host_permissions": [
    "https://wikidocs.net/*",
    "http://localhost:41184"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "WikiDocs Exporter 열기"
  },
  "side_panel": {
    "default_path": "side-panel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://wikidocs.net/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
