{
  "manifest_version": 3,
  "name": "WikiDocs Exporter",
  "version": "1.2.1",
  "description": "위키독스 컨텐츠를 Obsidian 또는 Joplin으로 내보내기",
  "homepage_url": "https://github.com/ejpark78/wikidocs-exporter",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "clipboardWrite",
    "sidePanel",
    "scripting"
  ],
  "host_permissions": [
    "https://wikidocs.net/*",
    "http://localhost:41184",
    "http://localhost:27123"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "WikiDocs Exporter 열기"
  },
  "side_panel": {
    "default_path": "src/side-panel/side-panel.html"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-loader-DMtoFMtQ.js"
      ],
      "matches": [
        "https://wikidocs.net/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://wikidocs.net/*"
      ],
      "resources": [
        "assets/storage-B_SUJJ_j.js",
        "assets/content.ts-Bjze7VuZ.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
